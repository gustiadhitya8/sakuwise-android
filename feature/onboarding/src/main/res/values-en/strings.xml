    <!-- Language screen -->
    <string name="onb_language_title">Let\'s get acquainted</string>
    <string name="onb_language_subtitle">Sakuwise is a local budget app — all data stays on your phone, no cloud, no tracking.</string>
    <string name="onb_language_cta">Start</string>
