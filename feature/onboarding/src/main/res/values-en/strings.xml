    <!-- Privacy screen -->
    <string name="onb_privacy_title">Your data stays here.</string>
    <string name="onb_privacy_subtitle">No server. No telemetry. No internet access requests.</string>
    <string name="onb_privacy_cta">I understand</string>
    <string name="onb_privacy_feat1_title">Encrypted on disk</string>
    <string name="onb_privacy_feat1_desc">Database &amp; receipt photos are all encrypted with AES-256.</string>
    <string name="onb_privacy_feat2_title">No account, no email</string>
    <string name="onb_privacy_feat2_desc">No login. Sakuwise doesn\'t know who you are.</string>
    <string name="onb_privacy_feat3_title">Backup is in your hands</string>
    <string name="onb_privacy_feat3_desc">Backup file is encrypted — you save it, you hold the PIN.</string>

