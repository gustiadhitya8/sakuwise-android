<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-backup rules for Android < API 31.
    On API 31+ this file is superseded by data_extraction_rules.xml.
    android:allowBackup="false" in the manifest already disables Auto Backup on
    older APIs; these rules are a belt-and-suspenders fallback.
-->
<full-backup-content>
    <exclude domain="database" path="sakuwise.db" />
    <exclude domain="database" path="sakuwise.db-wal" />
    <exclude domain="database" path="sakuwise.db-shm" />
    <exclude domain="file" path="dek.bin" />
    <exclude domain="file" path="pin.bin" />
    <exclude domain="sharedpref" path="sakuwise_autobackup_pin.xml" />
</full-backup-content>
