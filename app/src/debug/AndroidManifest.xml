<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <!-- Debug-only: lets adb skip the onboarding flow and seed PIN. -->
        <receiver
            android:name=".debugtools.DebugSkipOnboardingReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.gustiadhitya.sakuwise.debug.SKIP_ONBOARDING" />
            </intent-filter>
        </receiver>
        <!-- Debug-only: sets Drive backup prefs + creates fake local backup file for worker test. -->
        <receiver
            android:name=".debugtools.DebugDriveTestReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.gustiadhitya.sakuwise.debug.SETUP_DRIVE_TEST" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
